# Copy to .env and fill in your Microsoft Foundry credentials.
# The CLI auto-loads this file at startup.

# Foundry API key (from the Keys and Endpoint blade of your Foundry resource)
FOUNDRY_API_KEY=

# Foundry endpoint — must end in /v1 so the OpenAI SDK can hit /v1/responses
# Example: https://my-resource.services.ai.azure.com/openai/v1
FOUNDRY_ENDPOINT=

# Deployment name you created in Foundry (not an OpenAI model slug).
# Whatever you typed in the "Deployment name" field when you deployed the model.
SKILL_CLI_MODEL=gpt-5.4

# Optional: GitHub token so skill downloads aren't rate-limited (60/hr → 5000/hr).
# Create at https://github.com/settings/tokens — no scopes needed for public repos.
GITHUB_TOKEN=
